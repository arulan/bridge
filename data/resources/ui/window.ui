<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.7"/>

  <menu id="primary_menu">
    <section>
      <item>
        <attribute name="label" translatable="yes">_Set Up…</attribute>
        <attribute name="action">app.setup</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">_Configure Virtual Surround…</attribute>
        <attribute name="action">app.surround</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">_Preferences</attribute>
        <attribute name="action">app.preferences</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label" translatable="yes">_Keyboard Shortcuts</attribute>
        <attribute name="action">app.show-help-overlay</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">_About Dashboard</attribute>
        <attribute name="action">app.about</attribute>
      </item>
    </section>
  </menu>

  <template class="DashboardWindow" parent="AdwApplicationWindow">
    <property name="title">Dashboard</property>
    <property name="default-width">720</property>
    <property name="default-height">640</property>
    <property name="resizable">True</property>
    <child>
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar">
            <child type="end">
              <object class="GtkMenuButton">
                <property name="icon-name">open-menu-symbolic</property>
                <property name="menu-model">primary_menu</property>
                <property name="primary">true</property>
                <property name="tooltip-text">Menu</property>
              </object>
            </child>
          </object>
        </child>
        <property name="content">
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <child>
              <object class="AdwBanner" id="persist_banner">
                <property name="title">Virtual outputs will persist after your next login</property>
                <property name="button-label">Dismiss</property>
                <property name="revealed">False</property>
              </object>
            </child>
            <child>
              <object class="AdwBanner" id="shortcuts_banner">
                <property name="title">Global shortcuts are inactive</property>
                <property name="button-label">Dismiss</property>
                <property name="revealed">False</property>
              </object>
            </child>
            <child>
          <object class="GtkScrolledWindow">
            <property name="hscrollbar-policy">never</property>
            <property name="vexpand">true</property>
            <child>
              <object class="AdwClamp">
                <property name="maximum-size">840</property>
                <property name="tightening-threshold">600</property>
                <child>
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">16</property>
                    <property name="valign">start</property>
                    <property name="margin-top">16</property>
                    <property name="margin-bottom">16</property>
                    <property name="margin-start">16</property>
                    <property name="margin-end">16</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">horizontal</property>
                        <property name="spacing">16</property>
                        <property name="homogeneous">True</property>
                        <property name="valign">start</property>
                        <child>
                          <object class="GtkBox" id="aux_card">
                            <style><class name="card"/></style>
                            <property name="orientation">vertical</property>
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">12</property>
                                <property name="margin-top">16</property>
                                <property name="margin-bottom">16</property>
                                <property name="margin-start">16</property>
                                <property name="margin-end">16</property>
                                <!-- Heading row: title over sink-name subtitle + corner volume -->
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">6</property>
                                    <child>
                                      <object class="GtkBox">
                                        <property name="orientation">vertical</property>
                                        <property name="hexpand">True</property>
                                        <property name="valign">center</property>
                                        <child>
                                          <object class="GtkLabel">
                                            <style><class name="heading"/></style>
                                            <property name="label">Aux</property>
                                            <property name="xalign">0</property>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="label">Dashboard - Aux</property>
                                            <property name="xalign">0</property>
                                            <property name="ellipsize">end</property>
                                            <style><class name="caption"/></style>
                                            <style><class name="dim-label"/></style>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkBox" id="aux_volume_box">
                                        <property name="orientation">horizontal</property>
                                        <property name="spacing">2</property>
                                        <property name="valign">start</property>
                                        <property name="halign">end</property>
                                        <property name="baseline-position">bottom</property>
                                        <style><class name="card-volume-box"/></style>
                                        <child>
                                          <object class="GtkLabel" id="aux_volume_value">
                                            <property name="label">0.0</property>
                                            <property name="valign">baseline</property>
                                            <style><class name="card-volume"/></style>
                                            <style><class name="numeric"/></style>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkLabel" id="aux_volume_unit">
                                            <property name="label">dB</property>
                                            <property name="valign">baseline</property>
                                            <style><class name="card-volume-unit"/></style>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <!-- Action row: test tone + mute -->
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">6</property>
                                    <child>
                                      <object class="GtkBox">
                                        <property name="hexpand">True</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkButton" id="aux_test_tone_button">
                                        <property name="tooltip-text">Play a test tone through this output</property>
                                        <property name="valign">center</property>
                                        <style><class name="flat"/><class name="compact-icon-button"/></style>
                                        <child>
                                          <object class="GtkImage">
                                            <property name="icon-name">audio-x-generic-symbolic</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkToggleButton" id="aux_mute_button">
                                        <property name="tooltip-text">Mute this output</property>
                                        <property name="valign">center</property>
                                        <style><class name="flat"/><class name="compact-icon-button"/></style>
                                        <child>
                                          <object class="GtkImage" id="aux_mute_image">
                                            <property name="icon-name">audio-volume-high-symbolic</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkDropDown" id="aux_hw_dropdown">
                                    <property name="hexpand">True</property>
                                  </object>
                                </child>
                                <!-- Status row: channel layout + device type -->
                                <child>
                                  <object class="GtkBox" id="aux_status_row">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">6</property>
                                    <child>
                                      <object class="GtkLabel" id="aux_channels_label">
                                        <property name="xalign">0</property>
                                        <property name="valign">center</property>
                                        <property name="ellipsize">end</property>
                                        <style><class name="caption"/></style>
                                        <style><class name="dim-label"/></style>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLevelBar" id="aux_level_bar">
                                    <property name="hexpand">True</property>
                                    <property name="mode">continuous</property>
                                    <property name="min-value">0</property>
                                    <property name="max-value">1</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkBox" id="aux_disconnect_banner">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">8</property>
                                    <property name="visible">False</property>
                                    <style><class name="inline-banner"/><class name="error"/></style>
                                    <child>
                                      <object class="GtkImage">
                                        <property name="icon-name">dialog-warning-symbolic</property>
                                        <property name="valign">center</property>
                                        <property name="pixel-size">10</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">Output device disconnected</property>
                                        <property name="hexpand">True</property>
                                        <property name="xalign">0</property>
                                        <property name="valign">center</property>
                                        <property name="wrap">False</property>
                                        <property name="ellipsize">end</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkBox" id="main_card">
                            <style><class name="card"/></style>
                            <property name="orientation">vertical</property>
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">12</property>
                                <property name="margin-top">16</property>
                                <property name="margin-bottom">16</property>
                                <property name="margin-start">16</property>
                                <property name="margin-end">16</property>
                                <!-- Heading row: title over sink-name subtitle + corner volume -->
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">6</property>
                                    <child>
                                      <object class="GtkBox">
                                        <property name="orientation">vertical</property>
                                        <property name="hexpand">True</property>
                                        <property name="valign">center</property>
                                        <child>
                                          <object class="GtkLabel">
                                            <style><class name="heading"/></style>
                                            <property name="label">Main</property>
                                            <property name="xalign">0</property>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkLabel" id="main_subtitle_label">
                                            <property name="label">Dashboard - Main</property>
                                            <property name="xalign">0</property>
                                            <property name="ellipsize">end</property>
                                            <style><class name="caption"/></style>
                                            <style><class name="dim-label"/></style>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkBox" id="main_volume_box">
                                        <property name="orientation">horizontal</property>
                                        <property name="spacing">2</property>
                                        <property name="valign">start</property>
                                        <property name="halign">end</property>
                                        <property name="baseline-position">bottom</property>
                                        <style><class name="card-volume-box"/></style>
                                        <child>
                                          <object class="GtkLabel" id="main_volume_value">
                                            <property name="label">0.0</property>
                                            <property name="valign">baseline</property>
                                            <style><class name="card-volume"/></style>
                                            <style><class name="numeric"/></style>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkLabel" id="main_volume_unit">
                                            <property name="label">dB</property>
                                            <property name="valign">baseline</property>
                                            <style><class name="card-volume-unit"/></style>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <!-- Action row: mode toggle / surround setup + test tone + mute -->
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">6</property>
                                    <child>
                                      <object class="AdwToggleGroup" id="main_mode_toggle">
                                        <property name="visible">False</property>
                                        <property name="valign">center</property>
                                        <style><class name="compact-toggle"/></style>
                                        <child>
                                          <object class="AdwToggle">
                                            <property name="name">direct</property>
                                            <property name="label">Direct</property>
                                            <property name="icon-name">audio-speakers-symbolic</property>
                                            <property name="tooltip">Direct audio playback</property>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="AdwToggle">
                                            <property name="name">surround</property>
                                            <property name="label">Surround</property>
                                            <property name="icon-name">audio-headphones-symbolic</property>
                                            <property name="tooltip">Virtual Surround playback</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkButton" id="main_surround_setup_button">
                                        <property name="visible">False</property>
                                        <property name="valign">center</property>
                                        <property name="tooltip-text">Configure Virtual Surround</property>
                                        <style><class name="flat"/><class name="compact-button"/></style>
                                        <child>
                                          <object class="GtkBox">
                                            <property name="orientation">horizontal</property>
                                            <property name="spacing">6</property>
                                            <child>
                                              <object class="GtkImage">
                                                <property name="icon-name">audio-headphones-symbolic</property>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkLabel">
                                                <property name="label">Configure Virtual Surround…</property>
                                              </object>
                                            </child>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkBox">
                                        <property name="hexpand">True</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkButton" id="main_test_tone_button">
                                        <property name="tooltip-text">Play a test tone through this output</property>
                                        <property name="valign">center</property>
                                        <style><class name="flat"/><class name="compact-icon-button"/></style>
                                        <child>
                                          <object class="GtkImage">
                                            <property name="icon-name">audio-x-generic-symbolic</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkToggleButton" id="main_mute_button">
                                        <property name="tooltip-text">Mute this output</property>
                                        <property name="valign">center</property>
                                        <style><class name="flat"/><class name="compact-icon-button"/></style>
                                        <child>
                                          <object class="GtkImage" id="main_mute_image">
                                            <property name="icon-name">audio-volume-high-symbolic</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkDropDown" id="main_hw_dropdown">
                                    <property name="hexpand">True</property>
                                  </object>
                                </child>
                                <!-- Status row: channel layout + device type + default? -->
                                <child>
                                  <object class="GtkBox" id="main_status_row">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">6</property>
                                    <child>
                                      <object class="GtkLabel" id="main_channels_label">
                                        <property name="xalign">0</property>
                                        <property name="valign">center</property>
                                        <property name="ellipsize">end</property>
                                        <style><class name="caption"/></style>
                                        <style><class name="dim-label"/></style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel" id="main_default_tag">
                                        <property name="visible">False</property>
                                        <property name="label">· System Default</property>
                                        <property name="xalign">0</property>
                                        <property name="valign">center</property>
                                        <property name="ellipsize">end</property>
                                        <style><class name="caption"/></style>
                                        <style><class name="dim-label"/></style>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLevelBar" id="main_level_bar">
                                    <property name="hexpand">True</property>
                                    <property name="mode">continuous</property>
                                    <property name="min-value">0</property>
                                    <property name="max-value">1</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkBox" id="main_disconnect_banner">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">8</property>
                                    <property name="visible">False</property>
                                    <style><class name="inline-banner"/><class name="error"/></style>
                                    <child>
                                      <object class="GtkImage">
                                        <property name="icon-name">dialog-warning-symbolic</property>
                                        <property name="valign">center</property>
                                        <property name="pixel-size">10</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">Output device disconnected</property>
                                        <property name="hexpand">True</property>
                                        <property name="xalign">0</property>
                                        <property name="valign">center</property>
                                        <property name="wrap">False</property>
                                        <property name="ellipsize">end</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkBox" id="main_default_banner">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">8</property>
                                    <property name="visible">False</property>
                                    <style><class name="inline-banner"/></style>
                                    <child>
                                      <object class="GtkImage">
                                        <property name="icon-name">dialog-warning-symbolic</property>
                                        <property name="valign">center</property>
                                        <property name="pixel-size">10</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">Recommended as system default</property>
                                        <property name="hexpand">True</property>
                                        <property name="xalign">0</property>
                                        <property name="valign">center</property>
                                        <property name="wrap">False</property>
                                        <property name="ellipsize">end</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkButton" id="main_default_button">
                                        <property name="label">Set as default</property>
                                        <property name="valign">center</property>
                                        <style><class name="inline-banner-action"/></style>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkBox" id="main_surround_restart_banner">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">8</property>
                                    <property name="visible">False</property>
                                    <style><class name="inline-banner"/><class name="info"/></style>
                                    <child>
                                      <object class="GtkImage">
                                        <property name="icon-name">emblem-synchronizing-symbolic</property>
                                        <property name="valign">center</property>
                                        <property name="pixel-size">10</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel" id="main_surround_restart_label">
                                        <property name="label">Virtual Surround is available after your next login</property>
                                        <property name="hexpand">True</property>
                                        <property name="xalign">0</property>
                                        <property name="valign">center</property>
                                        <property name="wrap">False</property>
                                        <property name="ellipsize">end</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkBox" id="main_surround_error_banner">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">8</property>
                                    <property name="visible">False</property>
                                    <style><class name="inline-banner"/><class name="error"/></style>
                                    <child>
                                      <object class="GtkImage">
                                        <property name="icon-name">dialog-warning-symbolic</property>
                                        <property name="valign">center</property>
                                        <property name="pixel-size">10</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">Virtual Surround HRIR file not found</property>
                                        <property name="hexpand">True</property>
                                        <property name="xalign">0</property>
                                        <property name="valign">center</property>
                                        <property name="wrap">False</property>
                                        <property name="ellipsize">end</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">0</property>
                        <child>
                          <object class="GtkScale" id="mix_scale">
                            <property name="orientation">horizontal</property>
                            <property name="draw-value">False</property>
                            <property name="hexpand">True</property>
                            <property name="sensitive">False</property>
                            <property name="adjustment">
                              <object class="GtkAdjustment">
                                <property name="lower">-1.0</property>
                                <property name="upper">1.0</property>
                                <property name="value">0.0</property>
                                <property name="step-increment">0.1</property>
                                <property name="page-increment">0.25</property>
                              </object>
                            </property>
                            <marks>
                              <mark value="0" position="bottom"/>
                            </marks>
                          </object>
                        </child>
                      </object>
                    </child>
                    <!-- Routing tile -->
                    <child>
                      <object class="GtkBox" id="routing_tile">
                        <style><class name="card"/></style>
                        <property name="orientation">vertical</property>
                        <child>
                          <object class="GtkListBox" id="routing_header_list">
                            <property name="selection-mode">none</property>
                            <style><class name="routing-header-list"/></style>
                            <child>
                              <object class="GtkListBoxRow" id="routing_toggle">
                                <property name="activatable">True</property>
                                <accessibility>
                                  <property name="label">Routing</property>
                                  <state name="expanded">False</state>
                                </accessibility>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">12</property>
                                    <property name="margin-top">10</property>
                                    <property name="margin-bottom">10</property>
                                    <property name="margin-start">16</property>
                                    <property name="margin-end">16</property>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">Routing</property>
                                        <property name="valign">center</property>
                                        <property name="xalign">0</property>
                                        <style><class name="heading"/></style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel" id="routing_badge">
                                        <property name="label">0</property>
                                        <property name="valign">center</property>
                                        <property name="visible">False</property>
                                        <style><class name="routing-badge"/></style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkBox">
                                        <property name="hexpand">True</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkButton" id="routing_add_button">
                                        <property name="label">Add Rule</property>
                                        <property name="tooltip-text">Add routing rule</property>
                                        <property name="valign">center</property>
                                        <property name="sensitive">False</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkImage" id="routing_chevron">
                                        <property name="icon-name">pan-end-symbolic</property>
                                        <property name="valign">center</property>
                                        <property name="accessible-role">presentation</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkRevealer" id="routing_revealer">
                            <property name="reveal-child">False</property>
                            <property name="transition-type">slide-down</property>
                            <child>
                              <object class="GtkBox" id="routing_body">
                                <property name="orientation">vertical</property>
                                <property name="margin-start">16</property>
                                <property name="margin-end">16</property>
                                <property name="margin-bottom">12</property>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
            </child>
          </object>
        </property>
      </object>
    </child>
  </template>
</interface>
