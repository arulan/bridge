<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <!-- One sink definition, mounted at /aux/ and /main/ -->
  <schema id="io.github.arulan.Dashboard.sink">
    <key name="channels" type="i">
      <default>2</default>
      <summary>Channel count</summary>
    </key>
    <key name="position" type="s">
      <default>"FL,FR"</default>
      <summary>Channel positions</summary>
    </key>
    <key name="hw-name" type="s">
      <default>""</default>
      <summary>Hardware output node.name</summary>
    </key>
    <key name="display-name" type="s">
      <default>""</default>
      <summary>Hardware output display name</summary>
    </key>
  </schema>

  <!-- Optional virtual surround sink -->
  <schema id="io.github.arulan.Dashboard.surround">
    <key name="hrir-path" type="s">
      <default>""</default>
      <summary>Imported HRIR .wav path</summary>
    </key>
    <key name="hw-name" type="s">
      <default>""</default>
      <summary>Headphone output node.name</summary>
    </key>
    <key name="display-name" type="s">
      <default>""</default>
      <summary>Headphone output display name</summary>
    </key>
    <key name="active" type="b">
      <default>false</default>
      <summary>Virtual Surround toggle state on Main</summary>
    </key>
  </schema>

  <schema id="io.github.arulan.Dashboard" path="/io/github/arulan/Dashboard/">
    <child name="aux"  schema="io.github.arulan.Dashboard.sink"/>
    <child name="main" schema="io.github.arulan.Dashboard.sink"/>
    <child name="surround" schema="io.github.arulan.Dashboard.surround"/>

    <!-- (display_name, app_names, binaries, target, enabled) per rule -->
    <key name="rules" type="a(sasassb)">
      <default>[]</default>
      <summary>Routing rules</summary>
    </key>

    <key name="volume-display" type="s">
      <choices>
        <choice value="db"/>
        <choice value="percent"/>
      </choices>
      <default>'db'</default>
      <summary>Volume display format</summary>
    </key>
  </schema>
</schemalist>
