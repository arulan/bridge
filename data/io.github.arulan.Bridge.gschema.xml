<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <!-- One sink definition, mounted at /aux/ and /main/ -->
  <schema id="io.github.arulan.Bridge.sink">
    <key name="channels" type="i">
      <default>2</default>
      <summary>Channel count</summary>
    </key>
    <key name="position" type="s">
      <default>"FL,FR"</default>
      <summary>Channel positions</summary>
    </key>
    <key name="hw-name" type="s">
      <default>""</default>
      <summary>Hardware output node.name</summary>
    </key>
    <key name="display-name" type="s">
      <default>""</default>
      <summary>Hardware output display name</summary>
    </key>
  </schema>

  <!-- Optional virtual surround sink -->
  <schema id="io.github.arulan.Bridge.surround">
    <key name="hrir-path" type="s">
      <default>""</default>
      <summary>Imported HRIR .wav path</summary>
    </key>
    <key name="hw-name" type="s">
      <default>""</default>
      <summary>Headphone output node.name</summary>
    </key>
    <key name="display-name" type="s">
      <default>""</default>
      <summary>Headphone output display name</summary>
    </key>
    <key name="active" type="b">
      <default>false</default>
      <summary>Virtual Surround toggle state on Main</summary>
    </key>
  </schema>

  <schema id="io.github.arulan.Bridge" path="/io/github/arulan/Bridge/">
    <child name="aux"  schema="io.github.arulan.Bridge.sink"/>
    <child name="main" schema="io.github.arulan.Bridge.sink"/>
    <child name="surround" schema="io.github.arulan.Bridge.surround"/>

    <!-- (display_name, app_names, binaries, target, enabled) per rule -->
    <key name="rules" type="a(sasassb)">
      <default>[]</default>
      <summary>Routing rules</summary>
    </key>

    <!-- Quick Switch presets. Decided to use a vardict 
      so fields can be added later without invalidating presets  -->
    <key name="presets" type="aa{sv}">
      <default>[]</default>
      <summary>Quick Switch presets</summary>
    </key>
    <key name="presets-version" type="i">
      <default>1</default>
      <summary>Preset storage schema version</summary>
    </key>

    <key name="window-width" type="i">
      <default>720</default>
      <summary>Last window width</summary>
    </key>
    <key name="window-height" type="i">
      <default>640</default>
      <summary>Last window height</summary>
    </key>
    <key name="is-maximized" type="b">
      <default>false</default>
      <summary>Last window maximized state</summary>
    </key>

    <key name="keep-routing-open" type="b">
      <default>true</default>
      <summary>Expand the Routing tile on launch</summary>
    </key>

    <key name="default-follows-main" type="b">
      <default>false</default>
      <summary>The system default follows the virtual output driving Main</summary>
    </key>

    <key name="crossfade-step" type="i">
      <range min="2" max="25"/>
      <default>5</default>
      <summary>Crossfader travel in percentage</summary>
    </key>

    <key name="volume-display" type="s">
      <choices>
        <choice value="db"/>
        <choice value="percent"/>
      </choices>
      <default>'db'</default>
      <summary>Volume display format</summary>
    </key>
  </schema>
</schemalist>
