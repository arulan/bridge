<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.arulan.Dashboard</id>
  <name>Dashboard</name>
  <summary>A crossfade mixer</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <developer id="io.github.arulan">
    <name>arulan</name>
  </developer>

  <description>
    <p>
      A PipeWire crossfade mixer. Dashboard creates two virtual outputs that 
      you can route your audio to, and mix between them with a single control. 
      For example: send chat audio to one side, and game audio to the other.
    </p>
  </description>

  <launchable type="desktop-id">io.github.arulan.Dashboard.desktop</launchable>

  <url type="homepage">https://github.com/arulan/dashboard</url>
  <url type="bugtracker">https://github.com/arulan/dashboard/issues</url>
  <url type="vcs-browser">https://github.com/arulan/dashboard</url>

  <content_rating type="oars-1.1"/>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/arulan/dashboard/main/data/screenshots/main-window.png</image>
      <caption>The crossfade mixer</caption>
    </screenshot>
  </screenshots>

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
  </supports>

  <releases>
    <release version="0.4.0" date="2026-07-07">
      <description>
        <p>Early development release</p>
      </description>
    </release>
  </releases>
</component>
