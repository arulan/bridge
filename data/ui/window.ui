<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.4"/>

  <menu id="primary_menu">
    <section>
      <item>
        <attribute name="label" translatable="yes">_Set Up…</attribute>
        <attribute name="action">app.setup</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">_Preferences</attribute>
        <attribute name="action">app.preferences</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label" translatable="yes">_About Dashboard</attribute>
        <attribute name="action">app.about</attribute>
      </item>
    </section>
  </menu>

  <template class="DashboardWindow" parent="AdwApplicationWindow">
    <property name="title">Dashboard</property>
    <property name="default-width">720</property>
    <property name="default-height">640</property>
    <property name="resizable">True</property>
    <child>
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar">
            <child type="end">
              <object class="GtkMenuButton">
                <property name="icon-name">open-menu-symbolic</property>
                <property name="menu-model">primary_menu</property>
                <property name="primary">true</property>
                <property name="tooltip-text">Menu</property>
              </object>
            </child>
          </object>
        </child>
        <property name="content">
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <child>
              <object class="AdwBanner" id="persist_banner">
                <property name="title">Virtual outputs will persist after your next login</property>
                <property name="button-label">Dismiss</property>
                <property name="revealed">False</property>
              </object>
            </child>
            <child>
          <object class="GtkScrolledWindow">
            <property name="hscrollbar-policy">never</property>
            <property name="vexpand">true</property>
            <child>
              <object class="AdwClamp">
                <property name="maximum-size">840</property>
                <property name="tightening-threshold">600</property>
                <child>
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">16</property>
                    <property name="margin-top">16</property>
                    <property name="margin-bottom">16</property>
                    <property name="margin-start">16</property>
                    <property name="margin-end">16</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">horizontal</property>
                        <property name="spacing">16</property>
                        <property name="homogeneous">True</property>
                        <property name="valign">start</property>
                        <child>
                          <object class="GtkBox" id="aux_card">
                            <style><class name="card"/></style>
                            <property name="orientation">vertical</property>
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">12</property>
                                <property name="margin-top">16</property>
                                <property name="margin-bottom">16</property>
                                <property name="margin-start">16</property>
                                <property name="margin-end">16</property>
                                <child>
                                  <object class="GtkLabel">
                                    <style><class name="heading"/></style>
                                    <property name="label">Aux</property>
                                    <property name="xalign">0</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel">
                                    <style><class name="dim-label"/><class name="caption"/></style>
                                    <property name="label">Dashboard - Aux</property>
                                    <property name="xalign">0</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkDropDown" id="aux_hw_dropdown">
                                    <property name="hexpand">True</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkBox" id="main_card">
                            <style><class name="card"/></style>
                            <property name="orientation">vertical</property>
                            <child>
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">12</property>
                                <property name="margin-top">16</property>
                                <property name="margin-bottom">16</property>
                                <property name="margin-start">16</property>
                                <property name="margin-end">16</property>
                                <child>
                                  <object class="GtkLabel">
                                    <style><class name="heading"/></style>
                                    <property name="label">Main</property>
                                    <property name="xalign">0</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel">
                                    <style><class name="dim-label"/><class name="caption"/></style>
                                    <property name="label">Dashboard - Main</property>
                                    <property name="xalign">0</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkDropDown" id="main_hw_dropdown">
                                    <property name="hexpand">True</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkBox" id="main_default_banner">
                                    <property name="orientation">horizontal</property>
                                    <property name="spacing">8</property>
                                    <property name="visible">False</property>
                                    <style><class name="inline-banner"/></style>
                                    <child>
                                      <object class="GtkImage">
                                        <property name="icon-name">dialog-warning-symbolic</property>
                                        <property name="valign">center</property>
                                        <property name="pixel-size">10</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">Recommended as system default</property>
                                        <property name="hexpand">True</property>
                                        <property name="xalign">0</property>
                                        <property name="valign">center</property>
                                        <property name="wrap">False</property>
                                        <property name="ellipsize">end</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkButton" id="main_default_button">
                                        <property name="label">Set as default</property>
                                        <property name="valign">center</property>
                                        <style><class name="inline-banner-action"/></style>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">0</property>
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <child>
                              <object class="GtkLabel" id="aux_side_label">
                                <property name="label">Aux</property>
                                <property name="hexpand">True</property>
                                <property name="xalign">0</property>
                                <style>
                                  <class name="caption"/>
                                  <class name="dim-label"/>
                                  <class name="numeric"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="main_side_label">
                                <property name="label">Main</property>
                                <property name="xalign">1</property>
                                <style>
                                  <class name="caption"/>
                                  <class name="dim-label"/>
                                  <class name="numeric"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkScale" id="mix_scale">
                            <property name="orientation">horizontal</property>
                            <property name="draw-value">False</property>
                            <property name="hexpand">True</property>
                            <property name="sensitive">False</property>
                            <property name="adjustment">
                              <object class="GtkAdjustment">
                                <property name="lower">-1.0</property>
                                <property name="upper">1.0</property>
                                <property name="value">0.0</property>
                                <property name="step-increment">0.1</property>
                                <property name="page-increment">0.25</property>
                              </object>
                            </property>
                            <marks>
                              <mark value="0" position="bottom"/>
                            </marks>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
            </child>
          </object>
        </property>
      </object>
    </child>
  </template>
</interface>
